# ── Redis broker environment ──────────────────────────────────────────
# Used with: docker compose --profile redis --env-file .env.redis up
# Runs Redis for Celery broker/backend, keeps SQLite for app DB.

# Celery via Redis
CRAWLLMER_CELERY_BROKER_URL=redis://redis:6379/0
CRAWLLMER_CELERY_RESULT_BACKEND=redis://redis:6379/1
