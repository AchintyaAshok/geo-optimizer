# ── Local distributed environment ─────────────────────────────────────
# Used with: docker compose --profile distributed --env-file .env.local-distributed up
# Runs Postgres + Redis alongside the app services.

# Storage
CRAWLLMER_STORAGE_BACKEND=pgsql
CRAWLLMER_PG_HOST=postgres
CRAWLLMER_PG_PORT=5432
CRAWLLMER_PG_USER=crawllmer
CRAWLLMER_PG_PASSWORD=crawllmer
CRAWLLMER_PG_DATABASE=crawllmer

# Celery via Redis
CRAWLLMER_CELERY_BROKER_URL=redis://redis:6379/0
CRAWLLMER_CELERY_RESULT_BACKEND=redis://redis:6379/1
