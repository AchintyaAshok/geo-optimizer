# ──────────────────────────────────────────────────────────────────────
# crawllmer – Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
#
# All variables are prefixed with CRAWLLMER_ and map to
# src/crawllmer/config.py  (pydantic-settings).
# ──────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
# SQLAlchemy connection URL for the main application database.
# Stores crawl runs, work items, extracted pages, and generated artifacts.
# For production, consider using PostgreSQL:
#   CRAWLLMER_DB_URL=postgresql://user:pass@localhost:5432/crawllmer
CRAWLLMER_DB_URL=sqlite:///./crawllmer.db

# ── Celery Broker ────────────────────────────────────────────────────
# Message broker URL for the Celery task queue.
# Default uses SQLite via SQLAlchemy (no extra services needed).
# For production, use Redis:
#   CRAWLLMER_CELERY_BROKER_URL=redis://localhost:6379/0
CRAWLLMER_CELERY_BROKER_URL=sqla+sqlite:///./celery-broker.db

# ── Celery Result Backend ────────────────────────────────────────────
# Backend for storing Celery task results.
# Default uses SQLite. For production, use Redis:
#   CRAWLLMER_CELERY_RESULT_BACKEND=redis://localhost:6379/1
CRAWLLMER_CELERY_RESULT_BACKEND=db+sqlite:///./celery-results.db

# ── Worker ───────────────────────────────────────────────────────────
# How often (in seconds) the worker polls for new tasks.
CRAWLLMER_WORKER_POLL_SECONDS=2

# ── OpenTelemetry ──────────────────────────────────────────────────
# Set to send telemetry to an OTEL collector.
# When unset, telemetry is printed to stdout (console exporters).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
